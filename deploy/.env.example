############################################################################
# Presio self-hosted environment (Supabase + MinIO + the Presio app).
#
# Copy to deploy/.env and fill in. On Coolify, paste these as the Docker
# Compose resource's environment variables instead of committing a .env.
#
# ⚠️  CHANGE EVERY SECRET BELOW before the first boot. Generate the Supabase
#     secrets (JWT_SECRET / ANON_KEY / SERVICE_ROLE_KEY) with the official
#     helper:  https://supabase.com/docs/guides/self-hosting/docker#generate-api-keys
#     (or `sh utils/generate-keys.sh` from the supabase/docker repo).
############################################################################

############
# Domains — set these to YOUR real, externally-resolvable URLs.
#   APP_*    → where the Presio app is served (presio.example.com)
#   SUPABASE → where the Supabase API gateway (Kong) is served
#
# IMPORTANT: SUPABASE_PUBLIC_URL is used both by the browser AND by the Presio
# server to build the public PDF URLs handed to viewers, so it MUST be a real
# domain that resolves from outside the stack (Coolify gives you this). Plain
# `http://localhost:8000` only works for throwaway single-host testing.
############
SUPABASE_PUBLIC_URL=https://supabase.example.com
API_EXTERNAL_URL=https://supabase.example.com
SITE_URL=https://presio.example.com
# Comma-separated extra OAuth redirect targets (include localhost for dev).
ADDITIONAL_REDIRECT_URLS=https://presio.example.com,http://localhost:5173

# Host port the Presio app binds to (Coolify maps your app domain to this).
PRESIO_HTTP_PORT=3001
# Leave empty when the client is served same-origin (the default here).
ALLOWED_ORIGIN=

############
# Core secrets — CHANGE ALL OF THESE
############
POSTGRES_PASSWORD=your-super-secret-and-long-postgres-password
JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters-long
# Legacy HS256 API keys derived from JWT_SECRET (see the generate-keys helper).
# ANON_KEY is also used as the client's VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY.
ANON_KEY=paste-the-generated-anon-key-here
SERVICE_ROLE_KEY=paste-the-generated-service-role-key-here

# Opaque (sb_publishable_/sb_secret_) keys — optional, leave blank to use the
# legacy keys above.
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
JWT_KEYS=
JWT_JWKS=
ANON_KEY_ASYMMETRIC=
SERVICE_ROLE_KEY_ASYMMETRIC=

# Supabase Studio dashboard login (https://supabase.example.com).
DASHBOARD_USERNAME=supabase
DASHBOARD_PASSWORD=change-this-dashboard-password

# Used internally by Realtime / Supavisor / Studio-meta — change these too.
SECRET_KEY_BASE=change-this-to-a-64-char-random-string-aaaaaaaaaaaaaaaaaaaaaaaaaa
VAULT_ENC_KEY=change-this-32-character-key-min
PG_META_CRYPTO_KEY=change-this-encryption-key-32-chars-min

############
# Auth — GitHub OAuth + email/password
#
# Register a GitHub OAuth App with callback:
#   ${API_EXTERNAL_URL}/auth/v1/callback
# i.e. https://supabase.example.com/auth/v1/callback
############
GITHUB_ENABLED=true
GITHUB_CLIENT_ID=your-github-oauth-client-id
GITHUB_SECRET=your-github-oauth-client-secret

JWT_EXPIRY=3600
DISABLE_SIGNUP=false

# Email/password signup. Set AUTOCONFIRM=true to skip email verification (no
# SMTP needed); set false and configure SMTP_* for real confirmation emails.
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=true
ENABLE_ANONYMOUS_USERS=false
SMTP_ADMIN_EMAIL=admin@example.com
SMTP_HOST=supabase-mail
SMTP_PORT=2500
SMTP_USER=fake_mail_user
SMTP_PASS=fake_mail_password
SMTP_SENDER_NAME=Presio
MAILER_URLPATHS_CONFIRMATION="/auth/v1/verify"
MAILER_URLPATHS_INVITE="/auth/v1/verify"
MAILER_URLPATHS_RECOVERY="/auth/v1/verify"
MAILER_URLPATHS_EMAIL_CHANGE="/auth/v1/verify"

# Phone auth — unused by Presio, left at upstream defaults.
ENABLE_PHONE_SIGNUP=true
ENABLE_PHONE_AUTOCONFIRM=true

############
# Storage (MinIO-backed). GLOBAL_S3_BUCKET is the single MinIO bucket that
# holds all objects; the logical "presentations" bucket lives inside it and is
# created by dbschema.sql.
############
MINIO_ROOT_USER=presio-storage
MINIO_ROOT_PASSWORD=change-this-minio-password
GLOBAL_S3_BUCKET=presio-storage
REGION=us-east-1
STORAGE_TENANT_ID=presio
# S3 protocol endpoint creds (Supabase's own S3 API; unused by Presio but the
# storage service still reads them).
S3_PROTOCOL_ACCESS_KEY_ID=change-this-access-key-id
S3_PROTOCOL_ACCESS_KEY_SECRET=change-this-access-key-secret

############
# Database
############
POSTGRES_HOST=db
POSTGRES_DB=postgres
POSTGRES_PORT=5432

############
# Supavisor pooler — unused by Presio (the app talks to Kong, not Postgres
# directly), kept so the upstream stack boots unchanged.
############
POOLER_PROXY_PORT_TRANSACTION=6543
POOLER_DEFAULT_POOL_SIZE=20
POOLER_MAX_CLIENT_CONN=100
POOLER_TENANT_ID=presio
POOLER_DB_POOL_SIZE=5

############
# Studio dashboard
############
STUDIO_DEFAULT_ORGANIZATION=Presio
STUDIO_DEFAULT_PROJECT=Presio
OPENAI_API_KEY=

############
# Edge Functions — unused by Presio.
############
FUNCTIONS_VERIFY_JWT=false

############
# PostgREST
############
PGRST_DB_SCHEMAS=public,storage,graphql_public
PGRST_DB_MAX_ROWS=1000
PGRST_DB_EXTRA_SEARCH_PATH=public

############
# imgproxy / API gateway
############
IMGPROXY_AUTO_WEBP=true
KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443
