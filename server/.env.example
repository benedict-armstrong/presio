SUPABASE_URL=https://<your-project>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>
PORT=3001
# Comma-separated browser origins allowed for cross-origin API/socket access.
# Leave unset when the client is served from the same origin as the server.
# ALLOWED_ORIGIN=https://your-app.example.com

# Fully local / offline mode: swap Supabase for a bundled SQLite database and
# filesystem storage, so none of the above is needed (see server/local/ and
# local.docker-compose.yml). Login and sync-by-account are unavailable.
# PRESIO_MODE=local
# Where local mode keeps its SQLite file and uploaded PDFs. Default: ./data
# LOCAL_DATA_DIR=./data
# Set to false when no reverse proxy sits in front, so clients can't spoof
# their rate-limit IP via X-Forwarded-For. Default: trust one hop (Traefik).
# TRUST_PROXY=false

# Error tracking (Sentry or self-hosted GlitchTip). Leave empty to disable.
# SENTRY_DSN=https://<key>@<host>/<project>
# SENTRY_TRACES_SAMPLE_RATE=0.1
