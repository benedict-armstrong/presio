.env
node_modules/

# Supabase Studio saves ad-hoc SQL queries into its mounted volume; they're
# runtime data, not part of the deploy config.
deploy/volumes/snippets/

# Playwright E2E artifacts
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

# Local mode's SQLite DB + uploaded PDFs (PRESIO_MODE=local), default location
# when LOCAL_DATA_DIR isn't set.
/server/data/
