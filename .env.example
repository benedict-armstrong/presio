SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-publishable-key
# Comma-separated browser origins allowed for cross-origin API/socket access.
# Leave unset when the client is served from the same origin as the server.
# ALLOWED_ORIGIN=https://your-app.example.com

# Error tracking (Sentry or self-hosted GlitchTip). Leave empty to disable.
# SENTRY_DSN is read by the server; VITE_SENTRY_DSN is baked into the client.
# SENTRY_DSN=https://<key>@<host>/<project>
# VITE_SENTRY_DSN=https://<key>@<host>/<project>
