VITE_SUPABASE_URL=https://<your-project>.supabase.co
VITE_SUPABASE_PUBLISHABLE_DEFAULT_KEY=<your-publishable-key>

# Dev only: start signed in as a fake user (skips real auth) to test logged-in UI
# VITE_DEV_USER=dev@example.com

# Error tracking (Sentry or self-hosted GlitchTip). Leave empty to disable.
# VITE_SENTRY_DSN=https://<key>@<host>/<project>
